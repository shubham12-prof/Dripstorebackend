generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  cartItems CartItem[]
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  price       Int
  category    String
  sizes       String[]
  image       String
  description String
  tags        String[]
  createdAt   DateTime   @default(now())
  cartItems   CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId Int
  size      String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
